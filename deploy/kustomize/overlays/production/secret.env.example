# Copy this file to secret.env and fill in your values.
# Do NOT commit secret.env to source control.
#
# Generate OAUTH_HMAC_SECRET with:  openssl rand -base64 32
# Generate HEADSCALE_API_KEY with:  headscale apikeys create --expiration 8760h
#
# TAILNET_NAME must be an existing headscale user. Create a dedicated one for
# the operator (do not reuse OIDC-linked users):
#   headscale users create tailscale-operator
#
# oauth_client_id and oauth_client_secret must match the values in the
# operator-oauth Secret in the tailscale namespace (see deploy/kustomize/operator/).
# The Tailscale operator posts these to headtotails /oauth/token to obtain a
# bearer token for all subsequent management API calls.

headscale_api_key=hskey-api-CHANGEME
oauth_client_id=CHANGEME
oauth_client_secret=CHANGEME
oauth_hmac_secret=CHANGEME-32-byte-random-secret!!
tailnet_name=tailscale-operator
